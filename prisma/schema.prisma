generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Tabela do plugin nLogin (Minecraft) — compartilhada com o servidor
model Nlogin {
  id            Int      @id @default(autoincrement()) @map("ai")
  last_name     String
  unique_id     String?  @unique(map: "unique_id") @db.VarChar(32)
  mojang_id     String?  @unique(map: "mojang_id") @db.VarChar(32)
  bedrock_id    String?  @unique(map: "bedrock_id") @db.VarChar(32)
  password      String?
  ip            String?  @default("127.0.0.1") @map("last_ip") @db.VarChar(60)
  last_seen     DateTime @default(now()) @db.Timestamp(0)
  creation_date DateTime @default(now()) @db.Timestamp(0)
  email         String?
  discord       String?
  settings      String?  @db.MediumText

  user User?

  @@index([ip], map: "last_ip_idx")
  @@index([last_name], map: "last_name_idx")
  @@map("nlogin")
}

model User {
  id        String   @id @default(cuid())
  nloginId      Int       @unique @map("nlogin_id")
  email         String    @unique
  role          Role      @default(ALUNO)
  birthDate     DateTime? @map("birth_date") @db.Date
  deactivatedAt DateTime? @map("deactivated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  nlogin   Nlogin    @relation(fields: [nloginId], references: [id])
  profile  Profile?
  orders   Order[]
  posts    Post[]
  comments Comment[]
  reactions Reaction[]
  reports  Report[]
  blogPosts BlogPost[]
  passwordResetTokens PasswordResetToken[]
  cartItems CartItem[]

  @@map("users")
}

enum Role {
  ALUNO
  PROFESSOR
  MODERADOR
  ADMIN
}

model Profile {
  id                String  @id @default(cuid())
  userId            String  @unique @map("user_id")
  avatar            String? @db.VarChar(500)
  bio               String? @db.Text
  sapiensCoins      Int     @default(0) @map("sapiens_coins")
  xp                Int     @default(0)
  playtimeMinutes   Int     @default(0) @map("playtime_minutes")
  aulasConcluidas   Int     @default(0) @map("aulas_concluidas")
  rankingPosition   Int?    @map("ranking_position")
  perfilPublico     Boolean @default(true) @map("perfil_publico")
  mostrarTempoOnline Boolean @default(true) @map("mostrar_tempo_online")
  mostrarAtividade  Boolean @default(true) @map("mostrar_atividade")

  // Notification preferences
  notifForumRespostas  String @default("email") @map("notif_forum_respostas") @db.VarChar(10)
  notifLembretesAulas  String @default("email") @map("notif_lembretes_aulas") @db.VarChar(10)
  notifNovidades       String @default("off") @map("notif_novidades") @db.VarChar(10)
  notifResumoSemanal   String @default("off") @map("notif_resumo_semanal") @db.VarChar(10)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// Loja
model Product {
  id               String          @id @default(cuid())
  name             String          @db.VarChar(255)
  slug             String          @unique @db.VarChar(255)
  description      String          @db.Text
  shortDescription String?         @map("short_description") @db.VarChar(255)
  price            Decimal         @db.Decimal(10, 2)
  originalPrice    Decimal?        @map("original_price") @db.Decimal(10, 2)
  category         ProductCategory
  imageUrl         String?         @map("image_url") @db.VarChar(500)
  durationDays     Int?            @map("duration_days")
  benefits         String?         @db.Text
  serverCommand    String?         @map("server_command") @db.VarChar(500)
  stock            Int             @default(-1)
  featured         Boolean         @default(false)
  badge            String?         @db.VarChar(50)
  color            String?         @db.VarChar(20)
  order            Int             @default(0)
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now()) @map("created_at")

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@map("products")
}

enum ProductCategory {
  VIP
  RANK
  COSMETICO
  MOEDA
  KIT
}

model Order {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  paymentMethod   String?     @map("payment_method") @db.VarChar(50)
  paymentId       String?     @map("payment_id") @db.VarChar(255)
  couponId        String?     @map("coupon_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id])
  coupon Coupon?     @relation(fields: [couponId], references: [id])
  items  OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int    @default(1)
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(50)
  discount  Decimal  @db.Decimal(5, 2) // percentual
  maxUses   Int?     @map("max_uses")
  uses      Int      @default(0)
  active    Boolean  @default(true)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("coupons")
}

// Fórum
model ForumCategory {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  description String? @db.Text
  icon        String? @db.VarChar(50)
  order       Int     @default(0)
  staffOnly   Boolean @default(false) @map("staff_only")
  active      Boolean @default(true)

  topics Post[]

  @@map("forum_categories")
}

model Post {
  id             String    @id @default(cuid())
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(300)
  content        String    @db.Text
  authorId       String    @map("author_id")
  categoryId     String    @map("category_id")
  pinned         Boolean   @default(false)
  locked         Boolean   @default(false)
  resolved       Boolean   @default(false)
  views          Int       @default(0)
  tags           String?   @db.Text
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  author   User          @relation(fields: [authorId], references: [id])
  category ForumCategory @relation(fields: [categoryId], references: [id])
  comments Comment[]
  reactions Reaction[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String   @map("author_id")
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author  User      @relation(fields: [authorId], references: [id])
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  reactions Reaction[]

  @@map("comments")
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  postId    String?      @map("post_id")
  commentId String?      @map("comment_id")
  type      ReactionType

  user    User     @relation(fields: [userId], references: [id])
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("reactions")
}

enum ReactionType {
  LIKE
  DISLIKE
}

model Report {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  reason    String   @db.Text
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("reports")
}

// Blog
model BlogCategory {
  id   String @id @default(cuid())
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  blogPosts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  content     String   @db.LongText
  excerpt     String?  @db.Text
  coverImage  String?  @map("cover_image") @db.VarChar(500)
  authorId    String?  @map("author_id")
  categoryId  String   @map("category_id")
  tags        String?  @db.Text
  views       Int      @default(0)
  readTime    Int      @default(5) @map("read_time")
  published   Boolean  @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author   User?        @relation(fields: [authorId], references: [id])
  category BlogCategory @relation(fields: [categoryId], references: [id])

  @@map("blog_posts")
}

// Contato
model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  category  String   @db.VarChar(100)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Newsletter {
  id             String    @id @default(cuid())
  email          String    @unique @db.VarChar(255)
  confirmed      Boolean   @default(false)
  confirmToken   String?   @unique @map("confirm_token") @db.VarChar(255)
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("newsletter")
}

// Recuperação de senha
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Aulas
model Discipline {
  id               String   @id @default(cuid())
  name             String   @db.VarChar(100)
  slug             String   @unique @db.VarChar(100)
  description      String   @db.Text
  shortDescription String   @map("short_description") @db.VarChar(255)
  icon             String   @db.VarChar(50)
  color            String   @db.VarChar(20)
  banner           String?  @db.VarChar(500)
  levels           String   @db.VarChar(100)
  order            Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("website_disciplines")
}

model Lesson {
  id           String   @id @default(cuid())
  disciplineId String   @map("discipline_id")
  title        String   @db.VarChar(200)
  slug         String   @unique @db.VarChar(200)
  description  String   @db.Text
  order        Int      @default(0)
  duration     Int?     @map("duration_minutes")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  discipline Discipline @relation(fields: [disciplineId], references: [id])

  @@map("website_lessons")
}

// Carrinho de compras
model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("website_cart_items")
}
